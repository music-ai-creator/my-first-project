<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>AI音乐赚</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#121212;color:#fff;font-family:Arial,pingfang;padding-bottom:70px}
.header{padding:25px 20px;background:#1e1e2e}
.header h2{color:#00d4ff;margin-bottom:6px}
.main{padding:20px}
.item{background:#1e1e2e;padding:22px;border-radius:16px;margin:10px 0;font-size:16px;font-weight:bold}
.nav{position:fixed;bottom:0;left:0;right:0;display:flex;background:#1e1e2e;padding:10px 0}
.nav .item{flex:1;text-align:center;padding:10px 0;background:none;margin:0}
.ad-bottom{position:fixed;bottom:60px;left:0;right:0;background:#1e1e2e;color:#fff;padding:10px;text-align:center;font-size:12px}
</style>
</head>
<body>
<div class="header">
  <h2>AI音乐赚</h2>
  <p>创作音乐 · 免费下载 · 看广告赚钱</p >
</div>
<div class="main">
  <div class="item" onclick="go('lyric')">📝 AI智能写歌词</div>
  <div class="item" onclick="go('music')">🎧 AI生成歌曲</div>
  <div class="item" onclick="go('earn')">💰 赚钱中心</div>
  <div class="item" onclick="go('user')">👤 个人中心</div>
</div>
<div class="ad-bottom">📢 看广告赚金币 · 满5元可提现</div>
<div class="nav">
  <div class="item">首页</div>
  <div class="item" onclick="go('earn')">赚钱</div>
  <div class="item" onclick="go('user')">我的</div>
</div>

<script>
function go(p){location.href=p+".html"}

var adConfig = {coin:0,cash:0,adReward:100,signReward:100,inviteReward:1000,rate:10000}
function loadCoin(){var c=localStorage.getItem("coin");if(c)adConfig.coin=Number(c)}
window.onload=loadCoin
</script>
</body>
</html>
