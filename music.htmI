<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>AI生成歌曲</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#121212;color:#fff;font-family:Arial,pingfang;padding:20px;padding-bottom:70px}
.card{background:#1e1e2e;padding:20px;border-radius:16px;margin:10px 0}
button{width:100%;padding:15px;background:#00d4ff;color:#000;border:none;border-radius:10px;font-weight:bold;margin-top:10px}
audio{width:100%;margin-top:15px}
.back{position:fixed;bottom:10px;left:20px;right:20px;padding:14px;background:#1e1e2e;color:#fff;border-radius:10px;text-align:center}
.ad-tip{color:#00d4ff;font-size:12px;margin-top:5px}
</style>
</head>
<body>
<h2>🎧 AI生成歌曲</h2>
<div class="card">
  <p>输入歌词或风格</p >
  <textarea style="width:100%;height:120px;padding:12px;border-radius:10px;background:#2d2d3f;color:#fff;border:none" placeholder="粘贴歌词或写风格"></textarea>
  <button onclick="genMusic()">生成音乐</button>
  <button onclick="downMusic()">下载音乐</button>
  <div class="ad-tip">💡 下载前观看广告获得权限</div>
  <audio controls src="#" id="audio" style="display:none">
</div>
<div class="back" onclick="go('index')">返回首页</div>

<script>
var genMusicCount=0
function genMusic(){
  genMusicCount++
  if(genMusicCount>=2){
    alert("观看广告继续生成")
    showAd().then(()=>{genMusicCount=0})
    return
  }
  document.getElementById("audio").style.display="block"
  alert("音乐生成成功！")
}
function downMusic(){
  alert("先观看广告即可下载到本地")
  showAd().then(()=>{alert("开始下载音乐！")})
}

function go(p){location.href=p+".html"}

var adConfig={coin:0,cash:0,adReward:100,signReward:100,inviteReward:1000,rate:10000}
function loadCoin(){var c=localStorage.getItem("coin");if(c)adConfig.coin=Number(c)}
function showAd(){
  return new Promise(r=>{
    alert("🎬 广告播放完成！+"+adConfig.adReward+"金币")
    adConfig.coin+=adConfig.adReward
    localStorage.setItem("coin",adConfig.coin)
    r(true)
  })
}
window.onload=loadCoin
</script>
</body>
</html>
