<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>登录 - AI音乐赚</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#121212;color:#fff;font-family:Arial,pingfang}
.login-box{max-width:400px;margin:100px auto 0;padding:30px;background:#1e1e2e;border-radius:20px}
h2{text-align:center;margin-bottom:24px;color:#00d4ff}
input{width:100%;padding:14px;margin:10px 0;border-radius:10px;border:none;background:#2d2d3f;color:#fff;font-size:15px}
button{width:100%;padding:15px;background:#00d4ff;color:#000;border:none;border-radius:10px;font-size:16px;font-weight:bold;margin-top:10px}
.tip{text-align:center;margin-top:15px;font-size:13px;color:#999}
</style>
</head>
<body>
<div class="login-box">
  <h2>🎵 AI音乐赚</h2>
  <input type="text" id="phone" placeholder="请输入手机号">
  <input type="text" id="code" placeholder="请输入验证码">
  <button onclick="getCode()">获取验证码</button>
  <button onclick="login()">登录并开始赚钱</button>
  <p class="tip">未注册手机号将自动注册</p >
</div>
<li><a href=" " class="active">登录</a ></li>
<script>
function getCode(){alert("验证码已发送！")}
function login(){location.href="index.html"}

var adConfig = {coin:0,cash:0,adReward:100,signReward:100,inviteReward:1000,rate:10000}
function loadCoin(){var c=localStorage.getItem("coin");if(c)adConfig.coin=Number(c)}
window.onload=loadCoin
</script>
</body>
</html>
